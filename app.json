{
  "expo": {
    "name": "Thunkd",
    "slug": "thunkd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "thunkd",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tsilva.thunkd"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tsilva.thunkd",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Thunkd to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow Thunkd to use speech recognition."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "55dcff2f-9804-4742-b647-13b3d38fbd3f"
      },
      "router": {}
    }
  }
}
